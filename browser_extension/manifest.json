{
  "manifest_version": 3,
  "name": "UX Annotator",
  "version": "0.2",

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "offscreen"
  ],

  "host_permissions": [
    "https://localhost:3000/*",
    "<all_urls>"
],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}